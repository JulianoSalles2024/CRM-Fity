    {
      "parameters": {
        "jsCode": "const lead = $('Loop - Leads').first().json;\nconst convArr = $input.all().map(i => i.json);\nconst conv = Array.isArray(convArr[0]) ? convArr[0][0] : convArr[0];\n\nif (!conv || !conv.id) {\n  // No conversation found for this lead — skip\n  return [];\n}\n\nreturn [{\n  json: {\n    conversation_id: conv.id,\n    lead_id: lead.lead_id,\n    agent_id: lead.agent_id,\n    company_id: lead.company_id,\n    contact_identifier: conv.contact_identifier || lead.lead_phone || '',\n    input_text: '',\n    content_type: 'proactive'\n  }\n}];"
      },
