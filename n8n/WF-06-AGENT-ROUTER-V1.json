    {
      "parameters": {
        "jsCode": "// Get agent data from previous node (Check Work Hours)\nconst agent = $('Code - Check Work Hours').first().json;\n\n// Get leads from RPC response\nconst rawLeads = $input.all().map(i => i.json);\nconst leads = Array.isArray(rawLeads[0]) ? rawLeads[0] : rawLeads;\n\nif (!leads || leads.length === 0) {\n  return []; // No leads to process\n}\n\n// Attach agent context to each lead\nreturn leads.map(lead => ({\n  json: {\n    lead_id: lead.lead_id || lead.id,\n    lead_name: lead.name,\n    lead_phone: lead.phone,\n    agent_id: agent.id,\n    agent_name: agent.name,\n    company_id: agent.company_id,\n    function_type: agent.function_type\n  }\n}));"
      },
