    {
      "parameters": {
        "jsCode": "// Flatten agents array from HTTP response\nconst agents = $input.all().map(item => item.json);\n// If it's already a flat array of objects (Supabase REST returns JSON array)\nif (Array.isArray(agents[0])) {\n  return agents[0].map(a => ({ json: a }));\n}\nreturn agents.map(a => ({ json: a }));"
      },
      "id": "wf06-node-004",
      "name": "Code - Flatten Agents",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        720,
        200
      ]
    },
    {
      "parameters": {
        "batchSize": 1,
        "options": {}
      },
      "id": "wf06-node-005",
      "name": "Loop - Agents",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        960,
        200
      ]
    },
    {
      "parameters": {
        "jsCode": "const agent = $input.all()[0].json;\nconst now = new Date();\n\nconst tz = agent.timezone || 'America/Sao_Paulo';\n\nconst formatter = new Intl.DateTimeFormat('en-US', {\n  timeZone: tz,\n  hour: 'numeric',\n  minute: 'numeric',\n  hour12: false\n});\nconst parts = formatter.formatToParts(now);\nconst currentHour = parseInt(parts.find(p => p.type === 'hour').value);\nconst currentMinute = parseInt(parts.find(p => p.type === 'minute').value);\nconst currentTime = currentHour * 60 + currentMinute;\n\nconst parseTime = (t) => {\n  if (!t) return null;\n  const p = t.toString().split(':');\n  return parseInt(p[0]) * 60 + (parseInt(p[1] || 0));\n};\n\nconst start = parseTime(agent.work_hours_start) ?? 8 * 60;\nconst end = parseTime(agent.work_hours_end) ?? 18 * 60;\n\nconst dayFormatter = new Intl.DateTimeFormat('en-US', { timeZone: tz, weekday: 'short' });\nconst day = dayFormatter.format(now);\nconst isWeekday = !['Sat', 'Sun'].includes(day);\n\nconst withinHours = currentTime >= start && currentTime < end && isWeekday;\n\n// Return empty array if outside work hours — no IF node needed\nif (!withinHours) return [];\n\nreturn [{ json: { ...agent, _currentTime: currentTime, _day: day } }];"
      },
